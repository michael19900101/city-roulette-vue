
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Card, CardContent } from '@/components/ui/card'
---

<BaseLayout title="页面建设中 - 城市转盘">
  <div class="min-h-screen flex items-center justify-center p-4 bg-gradient-to-br from-primary/5 via-background to-secondary/5">
    <Card class="max-w-md w-full">
      <CardContent class="pt-6 text-center space-y-4">
        <div class="w-16 h-16 mx-auto rounded-full bg-muted flex items-center justify-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-muted-foreground"
          >
            <path d="M12 2v20M2 12h20" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-foreground">页面建设中</h1>
        <p class="text-muted-foreground">
          该页面正在开发中，敬请期待...
        </p>
        <a
          href="./home-explorer"
          class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          返回首页
        </a>
      </CardContent>
    </Card>
  </div>
</BaseLayout>
