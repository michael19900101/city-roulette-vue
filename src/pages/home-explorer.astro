
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import HomeExplorer from '@/components/home-explorer/HomeExplorer.vue'
---

<BaseLayout title="城市转盘 - 探索中国旅游城市">
  <div class="flex flex-col min-h-screen bg-gradient-radial-warm">
    <CommonHeader client:load />
    
    <main class="flex-1 overflow-y-auto">
      <HomeExplorer client:load />
    </main>
    
    <CommonFooter />
  </div>
</BaseLayout>

<style>
  :global(body) {
    overflow-x: hidden;
  }
</style>
